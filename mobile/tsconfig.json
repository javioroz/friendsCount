{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "moduleResolution": "node",
    "types": ["node"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "app/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}
