# FriendsCount - Environment Variables - Variables de entorno
# ==================================================================
# Copy this file and rename as .env configuring your env variable
# Copia este archivo como .env y configura tus variables de entorno

# ==================================================================
# Mobile (Development)
# ==================================================================
EXPO_ROUTER_APP_ROOT=mobile/app
EXPO_ROUTER_IMPORT_MODE=sync
EXPO_PUBLIC_GUN_RELAY=ws://localhost:3001/gun

# ==================================================================
# Server
# ==================================================================
PORT=3001
NODE_ENV=development

# ==================================================================
# Production (Uncomment and configure for Railway deployment)
# ==================================================================
# EXPO_PUBLIC_SERVER_URL=https://your-railway-app.up.railway.app
# EXPO_PUBLIC_GUN_RELAY=wss://your-railway-app.up.railway.app/gun
